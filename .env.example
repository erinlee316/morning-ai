# Copy to .env and fill in. Never commit .env.
#
# Every model call runs on Groq (llama-3.3-70b). The pipeline is mostly sequential,
# so the real bottleneck is a single key's per-minute token budget. The work is split
# across five keys, one per stage, so no single key absorbs the whole run. Each variable
# must be set — if you only have one Groq account, paste the same key into all five.

# Orchestrator ReAct loop (agent.py) — one call per step, highest volume
GROQ_API_KEY1=

# Signal scoring (score_signal) — one call per item
GROQ_API_KEY2=

# Analyst draft and final report synthesis
GROQ_API_KEY3=

# Reviewer critique, back-to-back with the analyst
GROQ_API_KEY4=

# Fetch-time source picks (Hacker News, arXiv, GitHub)
GROQ_API_KEY5=

# Optional: raises GitHub API rate limits for fetch_github.py
GITHUB_TOKEN=